#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define DECK_SIZE 52
#define MAX_HAND 11

// values to each of the cards to make the deck

void createDeck(int deck[])
{
    int i = 0;
    for (int suit = 0; suit < 4; suit++) {
        for (int val = 1; val <= 13; val++) {
            deck[i] = val;
            i++;
        }
    }
}
//fills deck 1-13 4 times for each suit
void shuffleDeck(int deck[])
{
    // deck shuffler using the 'fishar yates' algorithm
    int i, j, temp;
    for (i = DECK_SIZE - 1; i > 0; i--) {
        j = rand() % (i + 1);
        temp = deck[i];
        deck[i] = deck[j];
        deck[j] = temp;
    }
}
//fishar yates works by going thro the deck backwards and swapping each card with a random card

int cardValue(int card) {
    // face cards worth ten barring ace
    if (card == 11 || card == 12 || card == 13) return 10;
    return card;
}

int calculateScore(int hand[], int numCards) {
    // Ace seen as 11 until score goes past 21 then assume as 1
    int score = 0, aces = 0;
    for (int i = 0; i < numCards; i++) {
        if (hand[i] == 1) {
            aces++;
            score += 11;
        } else {
            score += cardValue(hand[i]);
        }
    }
    while (score > 21 && aces > 0) {
        score -= 10;
        aces--;
    }
    return score;
}


void printCardName(int card) {
    if (card == 1) printf("Ace");
    else if (card == 11) printf("Jack");
    else if (card == 12) printf("Queen");
    else if (card == 13) printf("King");
    else printf("%d", card);
}

void printHand(int hand[], int numCards, const char *label) {
    // shows cards and calcukates the score of the hand
    printf("%s", label);
    for (int i = 0; i < numCards; i++) {
        printf("  ");
        printCardName(hand[i]);
    }
    printf("  ->  score: %d\n", calculateScore(hand, numCards));
}


void playRound(int deck[], int *cardIndex) {
    // round is deal then players turn then dealers turn if no bust then compare score
    int playerHand[MAX_HAND], dealerHand[MAX_HAND];
    int playerCount = 0, dealerCount = 0;
    int playerScore, dealerScore;
    char choice;
    int done = 0;
    playerHand[playerCount++] = deck[(*cardIndex)++];
    dealerHand[dealerCount++] = deck[(*cardIndex)++];
    playerHand[playerCount++] = deck[(*cardIndex)++];
    dealerHand[dealerCount++] = deck[(*cardIndex)++];
    // shared by pointer so can keep track of deck to see when a shuffle is needed

    printf("\nNew round\n");
    printHand(playerHand, playerCount, "Your hand:    ");
    printf("Dealer shows:  ");
    printCardName(dealerHand[0]);
    printf("  [hidden card]\n");

    playerScore = calculateScore(playerHand, playerCount);
    dealerScore = calculateScore(dealerHand, dealerCount);
    if (playerScore == 21) {
        printf("BLACKJACK! You win!\n");
        return;
    }

    while (!done) {
        printf("\nHit or stand? (h/s) -> ");
        scanf(" %c", &choice);

        if (choice == 'H') choice = 'h';
        if (choice == 'S') choice = 's';
//checks bust
        if (choice == 'h') {
            // hit seen as dealing another card and then check for 21 or bust
            playerHand[playerCount++] = deck[(*cardIndex)++];
            printHand(playerHand, playerCount, "Your hand:    ");
            playerScore = calculateScore(playerHand, playerCount);
            if (playerScore > 21) {
                printf("You bust! Dealer wins.\n");
                return;
            }
            if (playerScore == 21) {
                printf("21 exactly\n");
                done = 1;
            }
        } else if (choice == 's') {
            done = 1;
        } else {
            printf("just type h or s\n");
        }
    }

    printf("\nDealer reveals the cards:\n");
    printHand(dealerHand, dealerCount, "Dealer hand:  ");
    while (dealerScore < 17) {
        // dealer follows fixed rule must hit below 17.
        dealerHand[dealerCount++] = deck[(*cardIndex)++];
        dealerScore = calculateScore(dealerHand, dealerCount);
        printHand(dealerHand, dealerCount, "Dealer hits:  ");
    }
    if (dealerScore > 21) {
        printf("Dealer busts! You win!\n");
        return;
    }
    playerScore = calculateScore(playerHand, playerCount);
    printf("\nFinal scores  ->  You: %d   Dealer: %d\n", playerScore, dealerScore);
    if (playerScore > dealerScore) printf("You win!\n");
    else if (dealerScore > playerScore) printf("Dealer wins.\n");
    else printf("Draw.\n");
}


int main() {
    // main loop keeps rounds going until player chooses to stop.
    int deck[DECK_SIZE];
    int cardIndex = 0;
    char again = 'y';

    srand(time(NULL));
    printf("Blackjack\n");
    

    createDeck(deck);
    shuffleDeck(deck);

    do {
        if (cardIndex > DECK_SIZE - 15) {
            printf("\nout of cards, reshuffling...\n");
            cardIndex = 0;
            shuffleDeck(deck);
        }
        playRound(deck, &cardIndex);
        printf("\nAnother round? (y/n): ");
        scanf(" %c", &again);
    } while (again == 'y' || again == 'Y');

    printf("\nGG\n");
    return 0;
}
//repeats rounds until player quits or has to reshuffle deck 
